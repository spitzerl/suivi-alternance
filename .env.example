# Database Config
POSTGRES_USER=admin
POSTGRES_PASSWORD=password123
POSTGRES_DB=alternance_db
DATABASE_URL=postgresql://admin:password123@db:5432/alternance_db

# Security
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=24h

# Deployment & Routing
DOMAIN_NAME=alternance.votre-domaine.fr

# Frontend & API
PORT=5000
# En production, utilisez l'URL complète : https://DOMAIN_NAME/api
VITE_API_URL=http://localhost:5000/api
# En production, utilisez https://DOMAIN_NAME
FRONTEND_ORIGIN=http://localhost:5173
